<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title | default("Bhaskar Goswami") }} | Bhaskar Goswami</title>
  <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body class="bg-space-950 text-starlight-50 font-sans antialiased">

  <!-- Starfield background -->
  <div class="starfield" id="starfield" aria-hidden="true">
    <div class="starfield-layer-1" id="stars1"></div>
    <div class="starfield-layer-2" id="stars2"></div>
  </div>

  <!-- Shooting stars -->
  <div class="shooting-star-container" aria-hidden="true">
    <div class="shooting-star"></div>
    <div class="shooting-star"></div>
  </div>

  <!-- Navigation -->
  <header class="content-layer sticky top-0 z-50 backdrop-blur-md bg-space-900/70 border-b border-space-700/50">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="{{ '/' | url }}" class="text-xl font-bold tracking-tight hover:text-nebula-400 transition-colors duration-300">
        Bhaskar Goswami
      </a>
      <nav class="flex items-center gap-1">
        <a href="{{ '/' | url }}"
           class="px-3 py-2 rounded-lg text-sm font-medium transition-all duration-300
                  {% if page.url == '/' %}text-nebula-400 bg-nebula-500/10
                  {% else %}text-starlight-200 hover:text-starlight-50 hover:bg-space-800/50{% endif %}">
          Home
        </a>
        <a href="{{ '/about/' | url }}"
           class="px-3 py-2 rounded-lg text-sm font-medium transition-all duration-300
                  {% if page.url == '/about/' %}text-nebula-400 bg-nebula-500/10
                  {% else %}text-starlight-200 hover:text-starlight-50 hover:bg-space-800/50{% endif %}">
          About
        </a>
        <a href="{{ '/research/' | url }}"
           class="px-3 py-2 rounded-lg text-sm font-medium transition-all duration-300
                  {% if page.url == '/research/' %}text-nebula-400 bg-nebula-500/10
                  {% else %}text-starlight-200 hover:text-starlight-50 hover:bg-space-800/50{% endif %}">
          Research
        </a>
        <a href="{{ '/publications/' | url }}"
           class="px-3 py-2 rounded-lg text-sm font-medium transition-all duration-300
                  {% if page.url == '/publications/' %}text-nebula-400 bg-nebula-500/10
                  {% else %}text-starlight-200 hover:text-starlight-50 hover:bg-space-800/50{% endif %}">
          Publications
        </a>
        <a href="{{ '/cv/' | url }}"
           class="px-3 py-2 rounded-lg text-sm font-medium transition-all duration-300
                  {% if page.url == '/cv/' %}text-nebula-400 bg-nebula-500/10
                  {% else %}text-starlight-200 hover:text-starlight-50 hover:bg-space-800/50{% endif %}">
          CV
        </a>
      </nav>
    </div>
  </header>

  <!-- Main content -->
  <main class="content-layer max-w-5xl mx-auto px-6 py-12">
    {{ content | safe }}
  </main>

  <!-- Footer -->
  <footer class="content-layer border-t border-space-700/50 bg-space-900/50">
    <div class="max-w-5xl mx-auto px-6 py-8 text-center">
      <p class="text-starlight-400 text-sm">&copy; 2026 Bhaskar Goswami. All rights reserved.</p>
    </div>
  </footer>

  <!-- Inline JavaScript -->
  <script>
    (function() {
      // Starfield generator
      function generateStars(count, layerId, isDim, spread) {
        var el = document.getElementById(layerId);
        if (!el) return;
        var shadows = [];
        var color = isDim ? 'oklch(0.68 0.08 265)' : '#fff';
        for (var i = 0; i < count; i++) {
          var x = Math.floor(Math.random() * spread);
          var y = Math.floor(Math.random() * spread);
          shadows.push(x + 'px ' + y + 'px ' + color);
        }
        el.style.boxShadow = shadows.join(', ');
      }

      var spread = Math.max(window.innerWidth, window.innerHeight, 2000);
      generateStars(200, 'stars1', false, spread);
      generateStars(100, 'stars2', true, spread);

      // Scroll-reveal Intersection Observer
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-fade-in-up');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.reveal').forEach(function(el) {
          observer.observe(el);
        });
      });
    })();
  </script>
</body>
</html>